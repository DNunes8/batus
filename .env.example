# Copy this file to .env.local and fill in values from Supabase dashboard:
# Project Settings -> API

# Project URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable / anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role / secret key (SERVER ONLY — never import into client components)
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) — optional. Without these, app emails are skipped
# (logged, never error). Get the key at resend.com -> API Keys.
# RESEND_FROM must be on a domain verified in Resend (e.g. batusboxe.com).
RESEND_API_KEY=
RESEND_FROM="Batus <ola@batusboxe.com>"

# --- Cron secret — shared between Vercel env and the GitHub Actions secret.
# Protects /api/cron/payment-reminders so only the scheduled job can fire it.
# Any long random string; must match in both places.
CRON_SECRET=
