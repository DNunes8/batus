# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code — local agent worktrees, not part of the repo
.claude/worktrees/

# stray screenshots / phone exports at project root
/IMG_*.PNG
/IMG_*.png
/WhatsApp Image *.jpeg
/WhatsApp Image *.jpg
/Batus Logo_*.png

# typescript
*.tsbuildinfo
